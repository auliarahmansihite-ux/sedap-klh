# Nginx configuration untuk SEDAP KLH
# Simpan di: /etc/nginx/sites-available/sedap-klh
# Lalu: sudo ln -s /etc/nginx/sites-available/sedap-klh /etc/nginx/sites-enabled/
# Lalu: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;  # Ganti dengan domain Anda

    # Redirect www ke non-www (opsional)
    # if ($host = www.your-domain.com) {
    #     return 301 https://your-domain.com$request_uri;
    # }

    # Batasi ukuran upload (sesuai server.js: 100MB)
    client_max_body_size 105M;

    # Logging
    access_log /var/log/nginx/sedap-klh.access.log;
    error_log  /var/log/nginx/sedap-klh.error.log;

    # Proxy semua request ke Node.js
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 120s;
    }

    # Cache aset statis langsung via Nginx (lebih cepat)
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|pdf|woff|woff2|svg)$ {
        proxy_pass       http://127.0.0.1:3000;
        proxy_set_header Host $host;
        expires          7d;
        add_header       Cache-Control "public, no-transform";
    }
}

# Setelah setup SSL dengan Certbot (Let's Encrypt):
# sudo certbot --nginx -d your-domain.com -d www.your-domain.com
