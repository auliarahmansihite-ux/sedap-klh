# Copy file ini menjadi .env dan sesuaikan nilainya

# Port server (default: 3000)
PORT=3000

# Path database SQLite
DB_PATH=./data/sedap-klh.db

# Salt untuk hashing IP — WAJIB diganti dengan string acak panjang!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT=sedap-klh-salt-2026-changeme

# Password login untuk tiap akun admin — WAJIB diganti sebelum deploy!
# Password hanya berlaku saat akun belum dibuat (first-run).
# Jika akun sudah ada di DB, ganti password via panel admin.
ADMIN_PASSWORD=ganti-password-admin-anda
RPPLH_PASSWORD=ganti-password-rpplh-anda
ZI_PASSWORD=ganti-password-zi-anda

# Nama aplikasi
APP_NAME=SEDAP KLH
